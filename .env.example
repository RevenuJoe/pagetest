# Anthropic API key (required) — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google PageSpeed Insights API key (optional but recommended)
# Without it the PSI API is heavily rate-limited.
# Get one at https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=
